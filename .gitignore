.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/dictionaries/
.idea/shelf/

# macOS metadata
.DS_Store
__MACOSX/

# Archive files that are not source
*.zip
*.jar

# Swap and temp files
*.swp
*~
swapfile.dat
